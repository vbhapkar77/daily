# Backend environment variables — copy to .env.local and fill in.
# Use these by exporting them in your shell before `./mvnw spring-boot:run`,
# or by IntelliJ run config "Environment variables" field.
#
# NEVER commit .env.local (it's gitignored).

# === Local dev defaults (talks to Docker Postgres) ===
# These match application-local.yml; you typically don't need to set them locally.
# SPRING_PROFILES_ACTIVE=local

# === Required for prod profile ===
# DATABASE_URL=jdbc:postgresql://ep-old-term-aqvxlvha.c-8.us-east-1.aws.neon.tech/daily?sslmode=require
# DATABASE_USERNAME=neondb_owner
# DATABASE_PASSWORD=
# JWT_SECRET=                          # 32+ random chars; generate with: openssl rand -base64 48
# APP_BASE_URL=https://daily.vercel.app
# RESEND_API_KEY=                       # from resend.com dashboard
